# Supabase project URL, for example:
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key. Do not use the service role secret key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# No admin, site URL, or auth redirect environment variables are required by the current app.
